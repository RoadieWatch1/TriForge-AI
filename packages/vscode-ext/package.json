{
  "name": "triforge-ai",
  "displayName": "Triforge AI Code Council",
  "description": "Structured tri-model AI Council — fast draft, risk analysis, cross-critique, and consensus",
  "version": "0.0.1",
  "publisher": "TriforgeAICodeCouncil",
  "icon": "media/TriForgeAI_logo.png",
  "license": "MIT",
  "homepage": "https://github.com/RoadieWatch1/TriForge-AI#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/RoadieWatch1/TriForge-AI.git"
  },
  "bugs": {
    "url": "https://github.com/RoadieWatch1/TriForge-AI/issues"
  },
  "keywords": [
    "ai",
    "code council",
    "consensus",
    "openai",
    "claude",
    "grok",
    "copilot",
    "multi-model",
    "debate",
    "code review"
  ],
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "triforge-ai.openPanel",
        "title": "TriForge AI: Open Council",
        "category": "TriForge AI"
      },
      {
        "command": "triforge-ai.openChat",
        "title": "TriForge AI: Open Council (alias)",
        "category": "TriForge AI"
      },
      {
        "command": "triforge-ai.setApiKey",
        "title": "TriForge AI: Add/Update API Key",
        "category": "TriForge AI"
      },
      {
        "command": "triforge-ai.removeApiKey",
        "title": "TriForge AI: Remove API Key",
        "category": "TriForge AI"
      },
      {
        "command": "triforge-ai.checkProviderStatus",
        "title": "TriForge AI: Check Provider Status",
        "category": "TriForge AI"
      },
      {
        "command": "triforge-ai.explainSelection",
        "title": "Explain Code",
        "category": "TriForge AI"
      },
      {
        "command": "triforge-ai.writeTests",
        "title": "Write Tests",
        "category": "TriForge AI"
      },
      {
        "command": "triforge-ai.refactorCode",
        "title": "Refactor Code",
        "category": "TriForge AI"
      },
      {
        "command": "triforge-ai.findBugs",
        "title": "Find Bugs",
        "category": "TriForge AI"
      },
      {
        "command": "triforge-ai.exportDebate",
        "title": "TriForge AI: Export Council Report as Markdown",
        "category": "TriForge AI"
      },
      {
        "command": "triforge-ai.activateLicense",
        "title": "TriForge AI: Activate License",
        "category": "TriForge AI"
      },
      {
        "command": "triforge-ai.deactivateLicense",
        "title": "TriForge AI: Remove License",
        "category": "TriForge AI"
      }
    ],
    "submenus": [
      {
        "id": "triforge-ai.submenu",
        "label": "TriForge AI"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "triforge-ai.submenu",
          "when": "editorHasSelection",
          "group": "triforge@1"
        }
      ],
      "triforge-ai.submenu": [
        {
          "command": "triforge-ai.explainSelection"
        },
        {
          "command": "triforge-ai.writeTests"
        },
        {
          "command": "triforge-ai.refactorCode"
        },
        {
          "command": "triforge-ai.findBugs"
        }
      ]
    },
    "keybindings": [
      {
        "command": "triforge-ai.openPanel",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "!terminalFocus"
      }
    ],
    "configuration": {
      "title": "TriForge AI",
      "properties": {
        "triforgeAi.mode": {
          "type": "string",
          "enum": [
            "guided",
            "professional"
          ],
          "default": "guided",
          "description": "UI mode: Guided (quick actions, beginner-friendly) or Professional (debate logs, iteration control)"
        },
        "triforgeAi.maxIterations": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum debate rounds in consensus mode (Professional mode)"
        },
        "triforgeAi.openai.model": {
          "type": "string",
          "default": "gpt-4o",
          "description": "OpenAI model to use"
        },
        "triforgeAi.grok.model": {
          "type": "string",
          "default": "grok-3",
          "description": "xAI Grok model to use (e.g. grok-3, grok-2)"
        },
        "triforgeAi.claude.model": {
          "type": "string",
          "default": "claude-sonnet-4-20250514",
          "description": "Anthropic Claude model to use"
        },
        "triforgeAi.riskTolerance": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "default": "medium",
          "description": "Think Tank risk tolerance: controls how conservative TriForge is when suggesting actions"
        },
        "triforgeAi.autoApprove": {
          "type": "boolean",
          "default": false,
          "description": "Auto-approve low-risk code patches without confirmation prompt"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:engine && node esbuild.js --production",
    "build:engine": "tsc -p ../engine/tsconfig.json",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc -p ./ --noEmit",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@triforge/engine": "*",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
