<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Required for Electron's JIT compiler (V8) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Required for Electron's WASM and Node.js addons -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Required for loading Electron's own frameworks -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Network access for AI API calls -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- File access (user-selected via open/save dialogs) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <!-- Downloads folder access -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
    <!-- Printer access -->
    <key>com.apple.security.print</key>
    <true/>
    <!-- Microphone access for Voice STT -->
    <key>com.apple.security.device.microphone</key>
    <true/>
  </dict>
</plist>
