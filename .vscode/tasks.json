{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "shell",
			"command": "npx tsc --build packages/engine packages/vscode-ext",
			"problemMatcher": "$tsc",
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"clear": true
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "watch",
			"type": "shell",
			"command": "npx tsc --build --watch packages/engine packages/vscode-ext",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			}
		}
	]
}
