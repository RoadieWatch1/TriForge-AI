{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "shell",
			"command": "npm run build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": "$esbuild-watch",
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"clear": true
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "watch",
			"type": "shell",
			"command": "npm run watch",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": "$esbuild-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			}
		},
		{
			"label": "build:desktop",
			"type": "shell",
			"command": "npm run build:desktop",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": "$esbuild-watch",
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "typecheck",
			"type": "shell",
			"command": "npm run typecheck",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": "$tsc"
		}
	]
}
