{
  "name": "triforge-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -p packages/engine/tsconfig.json && node packages/vscode-ext/esbuild.js",
    "build:prod": "tsc -p packages/engine/tsconfig.json && node packages/vscode-ext/esbuild.js --production",
    "watch": "node packages/vscode-ext/esbuild.js --watch",
    "typecheck": "tsc --build packages/engine && tsc -p packages/vscode-ext/tsconfig.json --noEmit"
  }
}
